# Copiá este archivo a ".env" (mismo directorio, junto a docker-compose.yml)
# y completá con valores reales antes de desplegar en un servidor público.
# ".env" NUNCA se sube al repo (ver .gitignore).

# Contraseña del usuario admin de Grafana. Si no seteás esta variable,
# Grafana usa "admin" como fallback (correcto para local, INSEGURO para
# un deploy público — cambiala acá).
GF_ADMIN_PASSWORD=pone-aca-una-password-fuerte
